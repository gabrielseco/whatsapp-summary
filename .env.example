# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Telegram — get token from @BotFather, chat ID by running: npm run setup
TELEGRAM_BOT_TOKEN=123456789:ABC-...
TELEGRAM_CHAT_ID=

# Schedule — 24h format, server local time (or set TZ below)
SUMMARY_HOUR=20

# Timezone for the cron schedule (e.g. Europe/Madrid, America/New_York)
TZ=Europe/Madrid
