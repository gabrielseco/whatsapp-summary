# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Secret token for HTTP routes (generate with: openssl rand -hex 32)
API_SECRET=

# Telegram — get token from @BotFather, chat ID by running: npm run setup
TELEGRAM_BOT_TOKEN=123456789:ABC-...
TELEGRAM_CHAT_ID=

# Schedule — 24h format, server local time (or set TZ below)
SUMMARY_HOUR=20

# Timezone for the cron schedule (e.g. Europe/Madrid, America/New_York)
TZ=Europe/Madrid

# Only needed for local setup on Mac (remove before deploying)
# PUPPETEER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
